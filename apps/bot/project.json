{
  "name": "bot",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "apps/bot",
  "sourceRoot": "apps/bot/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/bot"],
      "options": {
        "command": "npx tsc -p apps/bot/tsconfig.app.json"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc -p apps/bot/tsconfig.app.json && node dist/apps/bot/apps/bot/src/bot.js"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/apps/bot/apps/bot/src/bot.js"
      }
    }
  },
  "tags": []
}
